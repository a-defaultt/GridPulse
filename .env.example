# .env.example — copy to .env, fill in values, never commit .env to git

# ── Required ─────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your-app-password       # Gmail: use App Passwords, not account password
EMAIL_FROM=GridPulse <your@email.com>
EMAIL_TO=recipient1@email.com,recipient2@email.com  # V5: email_sender.py MUST loop over these individually to prevent spam/privacy leaks.

# ── Optional (have defaults) ─────────────────────────────────
DATABASE_PATH=data/GridPulse.db
SOURCES_YAML=sources.yaml
LOG_LEVEL=INFO                        # DEBUG | INFO | WARNING | ERROR
TIMEZONE=Africa/Tunis                 # pytz timezone name for email display

# ── API keys (optional, improve rate limits) ─────────────────
NVD_API_KEY=                          # Free at nvd.nist.gov/developers/request-an-api-key
                                      # Without key: 5 req/30s. With key: 50 req/30s.
OTX_API_KEY=                          # Required for AlienVault OTX source
                                      
# ── NVIDIA Build API Keys (build.nvidia.com) ─────────────────
# Free tier: get your API key at build.nvidia.com. One key works for all
# models, or use separate keys per feature for independent rate limits.
NVIDIA_SUMMARIZER_KEY=nvapi-...         # LLM batch summarization
NVIDIA_EMBEDDING_KEY=nvapi-...          # Semantic dedup embeddings
NVIDIA_CATEGORIZER_KEY=nvapi-...        # AI article categorization
NVIDIA_RERANKER_KEY=nvapi-...           # Neural reranking
NVIDIA_TIMEOUT_SECONDS=120

# ── LLM Standardized Endpoints (for batch summaries) ─────────
# V5 Enhancement: Standard openai client configuration. 
# Defaults to Nvidia NIM, but can be swapped to Groq/Together simply by changing the URL.
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_API_KEY=${NVIDIA_SUMMARIZER_KEY}   # Defaults to summarizer key, rotation handled in code
LLM_MODEL=meta/llama3-70b-instruct

# ── V5.2 AI Enhancement Models ───────────────────────────────
# These models power semantic dedup, AI categorization, and neural reranking.
# All three are available on build.nvidia.com free tier.
# Set AI_ENHANCEMENTS=false to disable and use traditional processing only.
AI_ENHANCEMENTS=true                    # Master toggle: true | false
EMBEDDING_MODEL=nvidia/llama-nemotron-embed-1b-v2      # Semantic deduplication
CATEGORIZER_MODEL=meta/llama-3.1-8b-instruct           # AI article categorization
RERANKER_MODEL=nvidia/llama-nemotron-rerank-1b-v2      # Neural reranking
SIMILARITY_THRESHOLD=0.85               # Cosine similarity threshold for dedup (0.0-1.0)
